# App Config — exposed to browser via NEXT_PUBLIC_ prefix
NEXT_PUBLIC_APP_URL=https://save-chatgpt-as-pdf.membasuh.com
NEXT_PUBLIC_GITHUB_URL=https://github.com/fyvri/save-chatgpt-as-pdf

# Upstash Redis — SERVER-ONLY. NEVER add NEXT_PUBLIC_ prefix to these.
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxx

# ScrapingAnt — optional proxy fallback when ChatGPT blocks the direct fetch.
# Sign up free (10 k requests/month) at https://app.scrapingant.com/signup
# Leave blank to disable; the "temporarily blocking" 503 error will still show.
SCRAPINGANT_API_KEY=bxxxxx
